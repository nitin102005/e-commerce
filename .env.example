# Server
PORT=5000
NODE_ENV=development

# MongoDB (MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secrets (use long random strings in production)
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Redis (Upstash Redis URL)
UPSTASH_REDIS_URL=rediss://default:<password>@<host>:<port>

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL for CORS (comma-separated if multiple origins)
# Required only when frontend and backend are hosted on different domains.
# Example: https://your-app.onrender.com
CLIENT_URL=http://localhost:5173

# Cookie sameSite policy: lax (default), strict, or none
# Use "none" only for cross-domain frontend/backend deployments over HTTPS.
COOKIE_SAME_SITE=lax

# Frontend only — set when API is on a different domain than the UI
# VITE_API_URL=https://your-api.onrender.com/api
